{% assign videos = site.static_files | where_exp: "video", "video.path contains '/assets/video/' and video.path contains '.mp4'" | sort: "path" %}

{% if videos.size > 0 %}
  <div class="row">
    {% for video in videos %}
      {% assign fileName = video.name | remove: ".mp4" %}
      <div class="col-lg-3 col-md-4 col-sm-6 col-xs-12 mb-4">
        <div class="card h-100">
          <div class="card-header" style="background: {{ site.data.theme.colors.secondary }}; color: white; text-align: center;">
            <small class="text-uppercase">Video</small>
          </div>
          <div class="card-body text-center">
            <div class="card-text">
              <span class="badge font-weight-bold danger-color-dark text-uppercase mb-2" style="min-width: 75px; display: inline-block;">
                {{ fileName }}
              </span>
              
              <h6 class="card-title font-weight-bold" style="font-size: 0.9rem;">
                <a href="{{ video.path | relative_url | bust_file_cache }}"
                   style="color: {{ site.data.theme.colors.primary }};">
                  {{ fileName }}
                </a>
              </h6>
              <p class="card-text text-muted font-weight-light" style="font-size: 0.85rem;">
                Video snippet
              </p>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% else %}
  <div class="text-center text-muted">
    No videos found yet.
  </div>
{% endif %}