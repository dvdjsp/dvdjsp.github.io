{% assign videos = site.static_files | where_exp: "video", "video.path contains '/assets/video/' and video.path contains '.mp4'" | sort: "path" | reverse %}

{% if videos.size > 0 %}
  {% assign prev_year = "" %}
  {% for video in videos %}
    {% assign fileName = video.name | remove: ".mp4" %}
    {% assign date_parts = fileName | split: '-' %}
    {% assign year = date_parts[0] %}
    {% assign month = date_parts[1] %}
    {% assign day = date_parts[2] %}
    
    {% if year != prev_year %}
      {% if prev_year != "" %}</div>{% endif %}
      <h3 style="margin-top: 2rem; padding: 10px 0; border-bottom: 2px solid #e8e8e8; color: #555;">{{ year }}</h3>
      <div class="row">
      {% assign prev_year = year %}
    {% endif %}
    
    <div class="col-lg-3 col-md-4 col-sm-6 col-xs-12 mb-4">
      <div class="card h-100">
        <video style="width: 100%; height: 200px; object-fit: cover; background: #000; cursor: pointer;" src="{{ video.path | relative_url | bust_file_cache }}" controls preload="metadata"></video>
        <div class="card-body text-center">
          <h6 class="card-title font-weight-bold" style="font-size: 0.85rem; margin-bottom: 0.5rem;">{{ fileName }}</h6>
          <p class="card-text text-muted font-weight-light" style="font-size: 0.8rem;">{{ month }}/{{ day }}/{{ year }}</p>
        </div>
      </div>
    </div>
  {% endfor %}
  </div>
{% else %}
  <div class="text-center text-muted">No videos found yet.</div>
{% endif %}